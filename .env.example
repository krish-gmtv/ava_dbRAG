# Postgres (precise KPI + row listings)
PRECISE_PG_HOST=localhost
PRECISE_PG_PORT=5432
PRECISE_PG_DB=ava_sandboxV2
PRECISE_PG_USER=postgres
PRECISE_PG_PASSWORD=

# Ava (optional — phrasing + embeddings; deterministic fallback works without Ava)
AVA_TOKEN=
AVA_USERNAME=
AVA_PASSWORD=
AVA_THREAD_ID=thread-001
AVA_APP_USER_ID=app-user-default

# Pinecone (optional — semantic retrieval / ingestion)
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=us-east-1-aws
PINECONE_INDEX_NAME=buyer-quarter-vectors

# Semantic catalog CSV override (optional)
# SEMANTIC_CATALOG_CSV=
